% =============================================================================
% beamerthememlsys-midnight.sty — Dark Mode Variant
% =============================================================================
% Dark navy background, white text, cyan accents.
% Clean, high-contrast, modern tech aesthetic.
% Swap: \usepackage{beamerthememlsys-midnight}
% =============================================================================

\ProvidesPackage{beamerthememlsys-midnight}[2026/03/16 ML Systems Dark Theme v1.0]

\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{calc}
\RequirePackage{setspace}
\RequirePackage[most]{tcolorbox}

\usetheme[
  progressbar=none,
  numbering=fraction,
  block=fill,
  sectionpage=none,
]{metropolis}

\AtBeginSection{%
  \begin{frame}[c]
    \sectionpage
  \end{frame}
}

% =============================================================================
% COLORS — Dark mode
% =============================================================================

\definecolor{midnight}{HTML}{0D1B2A}
\definecolor{darknavy}{HTML}{1B2838}
\definecolor{accent}{HTML}{00B4D8}
\definecolor{darkaccent}{HTML}{0077B6}
\definecolor{lightaccent}{HTML}{90E0EF}

\definecolor{computeblue}{HTML}{1A3A5C}
\definecolor{computestroke}{HTML}{48CAE4}
\definecolor{datagreen}{HTML}{1A3C2A}
\definecolor{datastroke}{HTML}{52B788}
\definecolor{routingorange}{HTML}{3C2A1A}
\definecolor{routingstroke}{HTML}{F4A261}
\definecolor{errorfill}{HTML}{3C1A1A}
\definecolor{errorstroke}{HTML}{E76F51}

\definecolor{darktext}{HTML}{E0E0E0}
\definecolor{midgray}{HTML}{A0A0A0}
\definecolor{lightgray}{HTML}{666666}
\definecolor{vlightgray}{HTML}{444444}

\definecolor{crimson}{HTML}{00B4D8}
\definecolor{darkcrimson}{HTML}{023E8A}
\definecolor{lightcrimson}{HTML}{48CAE4}

\setbeamercolor{normal text}{fg=darktext, bg=midnight}
\setbeamercolor{background canvas}{bg=midnight}
\setbeamercolor{palette primary}{bg=accent, fg=midnight}
\setbeamercolor{frametitle}{bg=midnight, fg=darktext}
\setbeamercolor{progress bar}{fg=accent}
\setbeamercolor{title separator}{fg=accent}
\setbeamercolor{alerted text}{fg=accent}

\setbeamercolor{block title}{bg=darknavy, fg=darktext}
\setbeamercolor{block body}{bg=midnight, fg=darktext}
\setbeamercolor{block title alerted}{bg=errorfill, fg=errorstroke}
\setbeamercolor{block body alerted}{bg=midnight, fg=darktext}
\setbeamercolor{block title example}{bg=datagreen, fg=datastroke}
\setbeamercolor{block body example}{bg=midnight, fg=darktext}

\setbeamercolor{section in head/foot}{fg=darktext, bg=darknavy}
\setbeamercolor{subsection in head/foot}{fg=darktext, bg=midnight}
\setbeamercolor{mini frame}{fg=accent, bg=darknavy}

% =============================================================================
% CONFIGURATION INTERFACE
% =============================================================================
\newcommand{\mlsysvolume}{Volume I}
\newcommand{\mlsyschapter}{Chapter 1}
\newcommand{\mlsyschaptertitle}{Introduction}
\newcommand{\mlsyslogopath}{../assets/img/logo-mlsysbook.png}
\newcommand{\mlsysinstlogo}{../assets/img/logo-harvard.png}

\newcommand{\mlsyssetup}[1]{\setkeys{mlsys}{#1}}
\RequirePackage{keyval}
\define@key{mlsys}{volume}{\renewcommand{\mlsysvolume}{#1}}
\define@key{mlsys}{chapter}{\renewcommand{\mlsyschapter}{#1}}
\define@key{mlsys}{chaptertitle}{\renewcommand{\mlsyschaptertitle}{#1}}
\define@key{mlsys}{logo}{\renewcommand{\mlsyslogopath}{#1}}
\define@key{mlsys}{instlogo}{\renewcommand{\mlsysinstlogo}{#1}}

% =============================================================================
% NAVIGATION
% =============================================================================
\setbeamertemplate{headline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.6ex, dp=0.8ex]{section in head/foot}%
    \hspace{0.3em}%
    {\fontsize{4.5}{5.5}\selectfont\insertsectionnavigationhorizontal{0.97\paperwidth}{}{}}%
    \hspace{0.3em}%
  \end{beamercolorbox}%
}

\setbeamersize{mini frame size=0.08cm, mini frame offset=0.04cm}
\setbeamertemplate{mini frame}[circle]
\setbeamercolor{mini frame}{fg=accent!70, bg=darknavy}

% =============================================================================
% FOOTER
% =============================================================================
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.3pt]{palette primary}%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, leftskip=0.7em, rightskip=0.7em]{normal text}%
    \raisebox{-0.2ex}{\includegraphics[height=2ex]{\mlsyslogopath}}%
    \hspace{0.3em}%
    {\fontsize{6}{7}\selectfont\textcolor{lightgray}{Machine Learning Systems — \mlsysvolume{} — \mlsyschapter: \mlsyschaptertitle}}%
    \hfill%
    {\fontsize{7}{8}\selectfont\textcolor{midgray}{\insertframenumber\,/\,\inserttotalframenumber}}%
    \hspace{0.3em}%
    \raisebox{-0.3ex}{\includegraphics[height=2.2ex]{\mlsysinstlogo}}%
  \end{beamercolorbox}%
}

\setbeamertemplate{navigation symbols}{}

% =============================================================================
% SECTION PAGE
% =============================================================================
\newcounter{mlsystotalsections}
\setcounter{mlsystotalsections}{6}

\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-0.3cm, yshift=0.3cm, opacity=0.06]
      at (current page.south east) {%
      \fontsize{140}{140}\selectfont\bfseries\textcolor{accent}{\thesection}%
    };
    \node[anchor=center] at (current page.center) {%
      \begin{minipage}{0.8\paperwidth}
        \centering
        {\small\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \textbar{} \mlsyschapter}}}\\[0.4cm]
        {\fontsize{30}{36}\selectfont\bfseries\textcolor{accent}{\insertsectionhead}}\\[0.5cm]
        {\color{accent}\rule{3cm}{1.2pt}}%
      \end{minipage}%
    };
  \end{tikzpicture}%
}

% =============================================================================
% TYPOGRAPHY
% =============================================================================
\setstretch{1.1}

\setbeamercolor{frametitle}{bg=midnight, fg=darktext}
\setbeamertemplate{frametitle}{%
  \vspace{0.3cm}%
  \insertframetitle%
  \par\vspace{-0.15cm}%
  {\color{accent!30}\rule{\textwidth}{0.5pt}}%
}

\setbeamertemplate{itemize item}{\raisebox{0.15ex}{\color{accent}\scriptsize$\blacksquare$}}
\setbeamertemplate{itemize subitem}{\raisebox{0.2ex}{\color{accent!60}\tiny$\blacktriangleright$}}
\setbeamertemplate{enumerate item}{\small\bfseries\color{accent}\insertenumlabel.}

\newtcolorbox{mlsyscard}[2][]{%
  enhanced, sharp corners, boxrule=0pt, frame hidden,
  borderline west={2.5pt}{0pt}{#2},
  colback=darknavy,
  left=0.8em, right=0.8em, top=0.4em, bottom=0.4em,
  fontupper=\small, #1
}

\newcommand{\mlsysfocus}[2]{%
  {%
  \setbeamercolor{background canvas}{bg=darkaccent}%
  \setbeamercolor{normal text}{fg=white}%
  \setbeamercolor{section in head/foot}{fg=white!50, bg=darkaccent}%
  \setbeamertemplate{footline}{%
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, rightskip=0.7em]{normal text}%
      \hfill{\fontsize{7}{8}\selectfont\textcolor{white!50}{\insertframenumber\,/\,\inserttotalframenumber}}%
      \hspace{0.3em}%
    \end{beamercolorbox}%
  }%
  \begin{frame}[c]
    \centering
    \begin{minipage}{0.8\paperwidth}
      \centering
      {\color{white!50}\rule{2cm}{0.8pt}}\\[0.5cm]
      {\huge\bfseries\color{white} #1}\\[0.5cm]
      {\large\color{white!85} #2}\\[0.5cm]
      {\color{white!50}\rule{2cm}{0.8pt}}
    \end{minipage}
  \end{frame}
  }%
}

\newcommand{\Dvol}{D_{\text{vol}}}
\newcommand{\Rpeak}{R_{\text{peak}}}
\newcommand{\Llat}{L_{\text{lat}}}
\newcommand{\Ttotal}{T_{\text{total}}}

\newcommand{\mlsystitle}[3]{%
  {
  \setbeamertemplate{headline}{}
  \setbeamertemplate{footline}{%
    \begin{beamercolorbox}[wd=\paperwidth, ht=0.6pt]{palette primary}\end{beamercolorbox}%
  }
  \begin{frame}[c]
    \begin{columns}[T]
      \begin{column}{0.60\textwidth}
        \vspace{1.2cm}
        {\footnotesize\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \; | \; \mlsyschapter}}}\\[0.3cm]
        {\Huge\bfseries\textcolor{accent}{#1}}\\[0.2cm]
        {\color{accent}\rule{5cm}{0.5pt}}\\[0.3cm]
        {\large #2}\\[1.0cm]
        {\normalsize\textbf{\insertauthor}}\\[0.1cm]
        {\small\textcolor{lightgray}{\insertinstitute}}\\[0.2cm]
        {\footnotesize\textcolor{vlightgray}{\insertdate}}
      \end{column}
      \begin{column}{0.37\textwidth}
        \vspace{0.3cm}
        \IfFileExists{#3}{\includegraphics[width=\textwidth]{#3}}{}
      \end{column}
    \end{columns}
    \vfill
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=south west, xshift=0.7cm, yshift=0.5cm] at (current page.south west) {%
        \includegraphics[height=1.0cm]{\mlsyslogopath}};
      \node[anchor=south east, xshift=-0.7cm, yshift=0.5cm] at (current page.south east) {%
        \includegraphics[height=1.0cm]{\mlsysinstlogo}};
    \end{tikzpicture}
  \end{frame}
  }
}

\newcommand{\mlsysconcept}[2]{{\textcolor{accent}{\textbf{#1}} \; #2}}
\newcommand{\mlsysalert}[2]{{\textcolor{errorstroke}{\textbf{#1}} \; #2}}
\newcommand{\mlsysinsight}[2]{{\textcolor{datastroke}{\textbf{#1}} \; #2}}

\newcommand{\mlsyscite}[1]{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-3.5cm, yshift=0.45cm,
          font=\fontsize{5}{6}\selectfont\color{vlightgray}]
      at (current page.south east) {#1};
  \end{tikzpicture}%
}

\newtcolorbox{mlsyscode}{%
  enhanced, sharp corners, boxrule=0pt, frame hidden,
  borderline west={2pt}{0pt}{midgray},
  colback=darknavy,
  left=0.6em, right=0.6em, top=0.3em, bottom=0.3em,
  fontupper=\small\ttfamily
}

\newcommand{\mlsysref}[2]{%
  {\small\textcolor{accent}{\textbf{[#1]}} #2}\\[0.2cm]%
}

\endinput
