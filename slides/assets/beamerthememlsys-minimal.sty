% =============================================================================
% beamerthememlsys-minimal.sty — Ultra-Clean Minimal Variant
% =============================================================================
% Pure white, no header bar, thin gray accents, maximum content space.
% Tufte-inspired: let the content breathe.
% Swap: \usepackage{beamerthememlsys-minimal}
% =============================================================================

\ProvidesPackage{beamerthememlsys-minimal}[2026/03/16 ML Systems Minimal Theme v1.0]

\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{calc}
\RequirePackage{setspace}
\RequirePackage[most]{tcolorbox}

\usetheme[progressbar=none, numbering=fraction, block=fill, sectionpage=none]{metropolis}

\AtBeginSection{\begin{frame}[c]\sectionpage\end{frame}}

\definecolor{accent}{HTML}{2D5F8A}
\definecolor{darkaccent}{HTML}{1A3D5C}
\definecolor{lightaccent}{HTML}{6B9DC2}
\definecolor{computeblue}{HTML}{CFE2F3}
\definecolor{computestroke}{HTML}{4A90C4}
\definecolor{datagreen}{HTML}{D4EDDA}
\definecolor{datastroke}{HTML}{3D9E5A}
\definecolor{routingorange}{HTML}{FDEBD0}
\definecolor{routingstroke}{HTML}{C87B2A}
\definecolor{errorfill}{HTML}{F9D6D5}
\definecolor{errorstroke}{HTML}{CC4444}
\definecolor{darktext}{HTML}{2C2C2C}
\definecolor{midgray}{HTML}{666666}
\definecolor{lightgray}{HTML}{AAAAAA}
\definecolor{vlightgray}{HTML}{DDDDDD}
\definecolor{crimson}{HTML}{2D5F8A}
\definecolor{darkcrimson}{HTML}{1A3D5C}
\definecolor{lightcrimson}{HTML}{6B9DC2}

\setbeamercolor{normal text}{fg=darktext, bg=white}
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{palette primary}{bg=accent, fg=white}
\setbeamercolor{frametitle}{bg=white, fg=darktext}
\setbeamercolor{alerted text}{fg=accent}
\setbeamercolor{block title}{bg=accent!8, fg=darktext}
\setbeamercolor{block body}{bg=accent!3, fg=darktext}
\setbeamercolor{block title alerted}{bg=errorfill, fg=errorstroke}
\setbeamercolor{block body alerted}{bg=errorfill!30, fg=darktext}
\setbeamercolor{block title example}{bg=datagreen, fg=datastroke}
\setbeamercolor{block body example}{bg=datagreen!30, fg=darktext}
\setbeamercolor{section in head/foot}{fg=white, bg=white}
\setbeamercolor{mini frame}{fg=accent, bg=accent!15}

\newcommand{\mlsysvolume}{Volume I}
\newcommand{\mlsyschapter}{Chapter 1}
\newcommand{\mlsyschaptertitle}{Introduction}
\newcommand{\mlsyslogopath}{../assets/img/logo-mlsysbook.png}
\newcommand{\mlsysinstlogo}{../assets/img/logo-harvard.png}
\newcommand{\mlsyssetup}[1]{\setkeys{mlsys}{#1}}
\RequirePackage{keyval}
\define@key{mlsys}{volume}{\renewcommand{\mlsysvolume}{#1}}
\define@key{mlsys}{chapter}{\renewcommand{\mlsyschapter}{#1}}
\define@key{mlsys}{chaptertitle}{\renewcommand{\mlsyschaptertitle}{#1}}
\define@key{mlsys}{logo}{\renewcommand{\mlsyslogopath}{#1}}
\define@key{mlsys}{instlogo}{\renewcommand{\mlsysinstlogo}{#1}}

\setbeamertemplate{headline}{}

\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.2pt]{palette primary}\end{beamercolorbox}%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.5ex, dp=1ex, leftskip=0.7em, rightskip=0.7em]{normal text}%
    {\fontsize{5.5}{6.5}\selectfont\textcolor{lightgray}{\mlsyschapter: \mlsyschaptertitle}}%
    \hfill%
    {\fontsize{6.5}{7.5}\selectfont\textcolor{midgray}{\insertframenumber\,/\,\inserttotalframenumber}}%
  \end{beamercolorbox}%
}

\setbeamertemplate{navigation symbols}{}

\newcounter{mlsystotalsections}
\setcounter{mlsystotalsections}{6}

\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-0.5cm, yshift=0.5cm, opacity=0.03]
      at (current page.south east) {\fontsize{160}{160}\selectfont\bfseries\textcolor{darktext}{\thesection}};
    \node[anchor=center] at (current page.center) {%
      \begin{minipage}{0.8\paperwidth}\centering
        {\footnotesize\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \textbar{} \mlsyschapter}}}\\[0.5cm]
        {\fontsize{28}{34}\selectfont\textcolor{darktext}{\insertsectionhead}}\\[0.5cm]
        {\color{vlightgray}\rule{4cm}{0.5pt}}%
      \end{minipage}};
  \end{tikzpicture}%
}

\setstretch{1.15}
\setbeamertemplate{frametitle}{\vspace{0.35cm}{\bfseries\insertframetitle}\par\vspace{-0.1cm}{\color{vlightgray}\rule{\textwidth}{0.3pt}}}
\setbeamertemplate{itemize item}{\raisebox{0.15ex}{\color{accent}\scriptsize$\bullet$}}
\setbeamertemplate{itemize subitem}{\raisebox{0.2ex}{\color{midgray}\tiny$\circ$}}
\setbeamertemplate{enumerate item}{\small\bfseries\color{accent}\insertenumlabel.}

\newtcolorbox{mlsyscard}[2][]{enhanced, sharp corners, boxrule=0pt, frame hidden, borderline west={2pt}{0pt}{#2}, colback=#2!4, left=0.8em, right=0.8em, top=0.4em, bottom=0.4em, fontupper=\small, #1}

\newcommand{\mlsysfocus}[2]{{%
  \setbeamercolor{background canvas}{bg=darkaccent}\setbeamercolor{normal text}{fg=white}%
  \setbeamertemplate{footline}{\begin{beamercolorbox}[wd=\paperwidth, ht=2.5ex, dp=1ex, rightskip=0.7em]{normal text}\hfill{\fontsize{6.5}{7.5}\selectfont\textcolor{white!50}{\insertframenumber\,/\,\inserttotalframenumber}}\end{beamercolorbox}}%
  \begin{frame}[c]\centering\begin{minipage}{0.8\paperwidth}\centering{\color{white!40}\rule{2cm}{0.5pt}}\\[0.5cm]{\huge\bfseries\color{white} #1}\\[0.5cm]{\large\color{white!85} #2}\\[0.5cm]{\color{white!40}\rule{2cm}{0.5pt}}\end{minipage}\end{frame}}}

\newcommand{\Dvol}{D_{\text{vol}}}
\newcommand{\Rpeak}{R_{\text{peak}}}
\newcommand{\Llat}{L_{\text{lat}}}
\newcommand{\Ttotal}{T_{\text{total}}}

\newcommand{\mlsystitle}[3]{{%
  \setbeamertemplate{footline}{}%
  \begin{frame}[c]\begin{columns}[T]
    \begin{column}{0.60\textwidth}\vspace{1.5cm}
      {\footnotesize\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \; | \; \mlsyschapter}}}\\[0.4cm]
      {\Huge\bfseries\textcolor{darktext}{#1}}\\[0.2cm]
      {\color{vlightgray}\rule{5cm}{0.3pt}}\\[0.4cm]
      {\large\textcolor{midgray}{#2}}\\[1.2cm]
      {\normalsize\textbf{\insertauthor}}\\[0.1cm]
      {\small\textcolor{lightgray}{\insertinstitute}}
    \end{column}
    \begin{column}{0.37\textwidth}\vspace{0.3cm}\IfFileExists{#3}{\includegraphics[width=\textwidth]{#3}}{}\end{column}
  \end{columns}\end{frame}}}

\newcommand{\mlsysconcept}[2]{{\textcolor{accent}{\textbf{#1}} \; #2}}
\newcommand{\mlsysalert}[2]{{\textcolor{errorstroke}{\textbf{#1}} \; #2}}
\newcommand{\mlsysinsight}[2]{{\textcolor{datastroke}{\textbf{#1}} \; #2}}
\newcommand{\mlsyscite}[1]{\begin{tikzpicture}[remember picture, overlay]\node[anchor=south east, xshift=-3.5cm, yshift=0.35cm, font=\fontsize{5}{6}\selectfont\color{lightgray}] at (current page.south east) {#1};\end{tikzpicture}}

\newtcolorbox{mlsyscode}{enhanced, sharp corners, boxrule=0pt, frame hidden, borderline west={1.5pt}{0pt}{midgray}, colback=vlightgray!20, left=0.6em, right=0.6em, top=0.3em, bottom=0.3em, fontupper=\small\ttfamily}

\newcommand{\mlsysref}[2]{{\small\textcolor{accent}{\textbf{[#1]}} #2}\\[0.2cm]}

\endinput
