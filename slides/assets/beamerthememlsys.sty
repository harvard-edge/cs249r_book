% =============================================================================
% beamerthememlsys.sty — ML Systems Lecture Slide Theme
% =============================================================================
% Custom Beamer theme for the ML Systems textbook lecture series.
% White background, crimson accents, section navigation dots,
% branded footer with logos, chapter context throughout.
%
% Usage in .tex:
%   \usepackage{beamerthememlsys}
%   \mlsyssetup{
%     volume = {Volume I},
%     chapter = {Chapter 1},
%     chaptertitle = {Introduction},
%   }
% =============================================================================

\ProvidesPackage{beamerthememlsys}[2026/03/16 ML Systems Lecture Theme v1.1]

\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{calc}
\RequirePackage{setspace}
\RequirePackage[most]{tcolorbox}

% =============================================================================
% BASE THEME
% =============================================================================
% Use metropolis as the base, then override everything we need.
\usetheme[
  progressbar=none,          % We use our own frametitle underline
  numbering=fraction,
  block=fill,
  sectionpage=none,          % We handle section pages ourselves (numbered)
]{metropolis}

% --- Section pages as numbered frames ---
\AtBeginSection{%
  \begin{frame}[c]
    \sectionpage
  \end{frame}
}

% =============================================================================
% COLORS
% =============================================================================

% --- Brand ---
\definecolor{crimson}{HTML}{A51C30}          % Vol 1 primary (Harvard Crimson)
\definecolor{darkcrimson}{HTML}{7A1020}
\definecolor{lightcrimson}{HTML}{D83A56}
\definecolor{ethblue}{HTML}{1F407A}          % Vol 2 primary (ETH Blue)

% --- Semantic (matching SVG style guide) ---
\definecolor{computeblue}{HTML}{CFE2F3}
\definecolor{computestroke}{HTML}{4A90C4}
\definecolor{datagreen}{HTML}{D4EDDA}
\definecolor{datastroke}{HTML}{3D9E5A}
\definecolor{routingorange}{HTML}{FDEBD0}
\definecolor{routingstroke}{HTML}{C87B2A}
\definecolor{errorfill}{HTML}{F9D6D5}
\definecolor{errorstroke}{HTML}{CC4444}

% --- Text ---
\definecolor{darktext}{HTML}{1A1A2E}
\definecolor{midgray}{HTML}{555555}
\definecolor{lightgray}{HTML}{999999}
\definecolor{vlightgray}{HTML}{CCCCCC}

% --- Apply to Beamer elements ---
\setbeamercolor{normal text}{fg=darktext, bg=white}
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{palette primary}{bg=crimson, fg=white}
\setbeamercolor{frametitle}{bg=crimson, fg=white}
\setbeamercolor{progress bar}{fg=crimson}
\setbeamercolor{title separator}{fg=crimson}
\setbeamercolor{alerted text}{fg=crimson}

% Blocks
\setbeamercolor{block title}{bg=crimson!12, fg=darktext}
\setbeamercolor{block body}{bg=crimson!4, fg=darktext}
\setbeamercolor{block title alerted}{bg=errorfill, fg=errorstroke}
\setbeamercolor{block body alerted}{bg=errorfill!30, fg=darktext}
\setbeamercolor{block title example}{bg=datagreen, fg=datastroke}
\setbeamercolor{block body example}{bg=datagreen!30, fg=darktext}

% Navigation
\setbeamercolor{section in head/foot}{fg=white, bg=crimson}
\setbeamercolor{subsection in head/foot}{fg=white, bg=darkcrimson}
\setbeamercolor{mini frame}{fg=crimson, bg=crimson!20}

% =============================================================================
% CONFIGURATION INTERFACE
% =============================================================================

\newcommand{\mlsysvolume}{Volume I}
\newcommand{\mlsyschapter}{Chapter 1}
\newcommand{\mlsyschaptertitle}{Introduction}
\newcommand{\mlsyslogopath}{../assets/img/logo-mlsysbook.png}
\newcommand{\mlsysinstlogo}{../assets/img/logo-harvard.png}

\newcommand{\mlsyssetup}[1]{%
  \setkeys{mlsys}{#1}%
}
\RequirePackage{keyval}
\define@key{mlsys}{volume}{\renewcommand{\mlsysvolume}{#1}}
\define@key{mlsys}{chapter}{\renewcommand{\mlsyschapter}{#1}}
\define@key{mlsys}{chaptertitle}{\renewcommand{\mlsyschaptertitle}{#1}}
\define@key{mlsys}{logo}{\renewcommand{\mlsyslogopath}{#1}}
\define@key{mlsys}{instlogo}{\renewcommand{\mlsysinstlogo}{#1}}

% =============================================================================
% NAVIGATION: Section name bar — no dots, just names
% =============================================================================

% Kill mini frames so only section names appear
\setbeamertemplate{mini frame}{}
\setbeamertemplate{mini frame in current section}{}
\setbeamertemplate{mini frame in current subsection}{}

\setbeamertemplate{headline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.4ex, dp=1ex, center]{section in head/foot}%
    {\fontsize{5}{6}\selectfont\strut\insertsectionnavigationhorizontal{0.96\paperwidth}{}{}}%
  \end{beamercolorbox}%
}

% =============================================================================
% FOOTER: Clean, minimal, branded (no navigation — that's in the header)
% =============================================================================

\setbeamertemplate{footline}{%
  % Thin accent line
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.3pt]{palette primary}%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, leftskip=0.7em, rightskip=0.7em]{normal text}%
    % Left: book logo + title
    \raisebox{-0.2ex}{\includegraphics[height=2ex]{\mlsyslogopath}}%
    \hspace{0.3em}%
    {\fontsize{6}{7}\selectfont\textcolor{lightgray}{Machine Learning Systems — \mlsysvolume{} — \mlsyschapter: \mlsyschaptertitle}}%
    \hfill%
    % Right: page number + institution logo
    {\fontsize{7}{8}\selectfont\textcolor{midgray}{\insertframenumber\,/\,\inserttotalframenumber}}%
    \hspace{0.3em}%
    \raisebox{-0.3ex}{\includegraphics[height=2.2ex]{\mlsysinstlogo}}%
  \end{beamercolorbox}%
}

% Disable bottom navigation symbols (the old-school Beamer icons)
\setbeamertemplate{navigation symbols}{}

% =============================================================================
% SECTION PAGE (Vertically centered, modern, with progress)
% =============================================================================

% Counter for total sections (set manually or auto-count)
\newcounter{mlsystotalsections}
\setcounter{mlsystotalsections}{6}  % Override per deck

\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture, overlay]
    % Large ghost section number for visual depth
    \node[anchor=south east, xshift=-0.3cm, yshift=0.3cm, opacity=0.04]
      at (current page.south east) {%
      \fontsize{140}{140}\selectfont\bfseries\textcolor{darktext}{\thesection}%
    };
    % Centered content
    \node[anchor=center] at (current page.center) {%
      \begin{minipage}{0.8\paperwidth}
        \centering
        {\small\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \textbar{} \mlsyschapter}}}\\[0.4cm]
        {\fontsize{30}{36}\selectfont\bfseries\textcolor{crimson}{\insertsectionhead}}\\[0.5cm]
        {\color{crimson}\rule{3cm}{1.2pt}}%
      \end{minipage}%
    };
  \end{tikzpicture}%
}

% =============================================================================
% TYPOGRAPHY & SPACING
% =============================================================================
\setstretch{1.1}

% =============================================================================
% FRAME TITLE (Floating style — white bg with thin underline)
% =============================================================================
\setbeamercolor{frametitle}{bg=white, fg=darktext}
\setbeamertemplate{frametitle}{%
  \vspace{0.3cm}%
  \hspace{0.3cm}\insertframetitle%
  \par\vspace{-0.15cm}%
  \hspace{0.3cm}{\color{crimson!25}\rule{0.95\textwidth}{0.5pt}}%
}

% --- Frame body margins ---
\setbeamersize{text margin left=0.6cm, text margin right=0.6cm}

% =============================================================================
% LIST STYLING (Modern squares and triangles)
% =============================================================================
\setbeamertemplate{itemize item}{\raisebox{0.15ex}{\color{crimson}\scriptsize$\blacksquare$}}
\setbeamertemplate{itemize subitem}{\raisebox{0.2ex}{\color{crimson!60}\tiny$\blacktriangleright$}}
\setbeamertemplate{enumerate item}{\small\bfseries\color{crimson}\insertenumlabel.}

% =============================================================================
% CARD-STYLE CALLOUTS (tcolorbox — modern replacement for blocks)
% =============================================================================
\newtcolorbox{mlsyscard}[2][]{%
  enhanced,
  sharp corners,
  boxrule=0pt,
  frame hidden,
  borderline west={2.5pt}{0pt}{#2},
  colback=#2!5,
  left=0.8em, right=0.8em, top=0.4em, bottom=0.4em,
  fontupper=\small,
  #1
}

% =============================================================================
% FOCUS FRAME (Dark background for key equations — numbered)
% =============================================================================
\newcommand{\mlsysfocus}[2]{%
  {%
  \setbeamercolor{background canvas}{bg=darkcrimson}%
  \setbeamercolor{normal text}{fg=white}%
  \setbeamercolor{section in head/foot}{fg=white!50, bg=darkcrimson}%
  \setbeamercolor{palette primary}{bg=white!20}%
  \setbeamertemplate{footline}{%
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, rightskip=0.7em]{normal text}%
      \hfill{\fontsize{7}{8}\selectfont\textcolor{white!50}{\insertframenumber\,/\,\inserttotalframenumber}}%
      \hspace{0.3em}%
    \end{beamercolorbox}%
  }%
  \begin{frame}[c]
    \centering
    \begin{minipage}{0.8\paperwidth}
      \centering
      {\color{white!50}\rule{2cm}{0.8pt}}\\[0.5cm]
      {\huge\bfseries\color{white} #1}\\[0.5cm]
      {\large\color{white!85} #2}\\[0.5cm]
      {\color{white!50}\rule{2cm}{0.8pt}}
    \end{minipage}
  \end{frame}
  }%
}

% =============================================================================
% CUSTOM COMMANDS
% =============================================================================

% --- Math shortcuts ---
\newcommand{\Dvol}{D_{\text{vol}}}
\newcommand{\Rpeak}{R_{\text{peak}}}
\newcommand{\Llat}{L_{\text{lat}}}
\newcommand{\Ttotal}{T_{\text{total}}}

% --- Title slide (numbered) ---
\newcommand{\mlsystitle}[3]{%
  % #1 = title, #2 = subtitle, #3 = cover image path
  {
  \setbeamertemplate{headline}{}
  \setbeamertemplate{footline}{%
    \begin{beamercolorbox}[wd=\paperwidth, ht=0.6pt]{palette primary}\end{beamercolorbox}%
  }
  \begin{frame}[c]
    \begin{columns}[T]
      \begin{column}{0.60\textwidth}
        \vspace{1.2cm}
        {\footnotesize\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \; | \; \mlsyschapter}}}\\[0.3cm]
        {\Huge\bfseries\textcolor{crimson}{#1}}\\[0.2cm]
        {\color{crimson}\rule{5cm}{0.5pt}}\\[0.3cm]
        {\large #2}\\[1.0cm]
        {\normalsize\textbf{\insertauthor}}\\[0.1cm]
        {\small\textcolor{lightgray}{\insertinstitute}}\\[0.2cm]
        {\footnotesize\textcolor{vlightgray}{\insertdate}}
      \end{column}
      \begin{column}{0.37\textwidth}
        \vspace{0.3cm}
        \IfFileExists{#3}{%
          \includegraphics[width=\textwidth]{#3}%
        }{}
      \end{column}
    \end{columns}
    % Logos at bottom
    \vfill
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=south west, xshift=0.7cm, yshift=0.5cm] at (current page.south west) {%
        \includegraphics[height=1.0cm]{\mlsyslogopath}%
      };
      \node[anchor=south east, xshift=-0.7cm, yshift=0.5cm] at (current page.south east) {%
        \includegraphics[height=1.0cm]{\mlsysinstlogo}%
      };
    \end{tikzpicture}
  \end{frame}
  }
}

% --- Concept highlight (inline, no block padding) ---
\newcommand{\mlsysconcept}[2]{%
  % #1 = title, #2 = body
  {\textcolor{crimson}{\textbf{#1}} \; #2}%
}

% --- Alert inline (for pitfalls/fallacies without block) ---
\newcommand{\mlsysalert}[2]{%
  % #1 = title, #2 = body
  {\textcolor{errorstroke}{\textbf{#1}} \; #2}%
}

% --- Insight inline (for examples/tips without block) ---
\newcommand{\mlsysinsight}[2]{%
  % #1 = title, #2 = body
  {\textcolor{datastroke}{\textbf{#1}} \; #2}%
}

% --- Footer citation (tiny, gray, right-aligned above footer) ---
\newcommand{\mlsyscite}[1]{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-3.5cm, yshift=0.45cm,
          font=\fontsize{5}{6}\selectfont\color{vlightgray}]
      at (current page.south east) {#1};
  \end{tikzpicture}%
}

% --- Code listing box ---
\newtcolorbox{mlsyscode}{%
  enhanced,
  sharp corners,
  boxrule=0pt,
  frame hidden,
  borderline west={2pt}{0pt}{midgray},
  colback=vlightgray!30,
  left=0.6em, right=0.6em, top=0.3em, bottom=0.3em,
  fontupper=\small\ttfamily
}

% --- References slide helper ---
\newcommand{\mlsysref}[2]{%
  % #1 = citation key, #2 = description
  {\small\textcolor{crimson}{\textbf{[#1]}} #2}\\[0.2cm]%
}

\endinput
