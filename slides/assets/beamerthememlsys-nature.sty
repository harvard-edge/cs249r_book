% =============================================================================
% beamerthememlsys-nature.sty — Warm Nature/Earth Variant
% =============================================================================
% Deep forest green accent, warm grays. Academic journal aesthetic.
% Swap: \usepackage{beamerthememlsys-nature}
% =============================================================================

\ProvidesPackage{beamerthememlsys-nature}[2026/03/16 ML Systems Nature Theme v1.0]

\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{calc}
\RequirePackage{setspace}
\RequirePackage[most]{tcolorbox}

\usetheme[progressbar=none, numbering=fraction, block=fill, sectionpage=none]{metropolis}

\AtBeginSection{\begin{frame}[c]\sectionpage\end{frame}}

\definecolor{forest}{HTML}{2D6A4F}
\definecolor{darkforest}{HTML}{1B4332}
\definecolor{lightforest}{HTML}{52B788}
\definecolor{computeblue}{HTML}{CFE2F3}
\definecolor{computestroke}{HTML}{4A90C4}
\definecolor{datagreen}{HTML}{D8F3DC}
\definecolor{datastroke}{HTML}{2D6A4F}
\definecolor{routingorange}{HTML}{FDEBD0}
\definecolor{routingstroke}{HTML}{BC6C25}
\definecolor{errorfill}{HTML}{F9D6D5}
\definecolor{errorstroke}{HTML}{AE2012}
\definecolor{darktext}{HTML}{2B2D26}
\definecolor{midgray}{HTML}{5C5C52}
\definecolor{lightgray}{HTML}{9C9C8E}
\definecolor{vlightgray}{HTML}{D4D4C8}
\definecolor{crimson}{HTML}{2D6A4F}
\definecolor{darkcrimson}{HTML}{1B4332}
\definecolor{lightcrimson}{HTML}{52B788}

\setbeamercolor{normal text}{fg=darktext, bg=white}
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{palette primary}{bg=forest, fg=white}
\setbeamercolor{frametitle}{bg=white, fg=darktext}
\setbeamercolor{alerted text}{fg=forest}
\setbeamercolor{block title}{bg=forest!10, fg=darktext}
\setbeamercolor{block body}{bg=forest!3, fg=darktext}
\setbeamercolor{block title alerted}{bg=errorfill, fg=errorstroke}
\setbeamercolor{block body alerted}{bg=errorfill!30, fg=darktext}
\setbeamercolor{block title example}{bg=datagreen, fg=datastroke}
\setbeamercolor{block body example}{bg=datagreen!30, fg=darktext}
\setbeamercolor{section in head/foot}{fg=white, bg=forest}
\setbeamercolor{subsection in head/foot}{fg=white, bg=darkforest}
\setbeamercolor{mini frame}{fg=forest, bg=forest!20}

\newcommand{\mlsysvolume}{Volume I}
\newcommand{\mlsyschapter}{Chapter 1}
\newcommand{\mlsyschaptertitle}{Introduction}
\newcommand{\mlsyslogopath}{../assets/img/logo-mlsysbook.png}
\newcommand{\mlsysinstlogo}{../assets/img/logo-harvard.png}
\newcommand{\mlsyssetup}[1]{\setkeys{mlsys}{#1}}
\RequirePackage{keyval}
\define@key{mlsys}{volume}{\renewcommand{\mlsysvolume}{#1}}
\define@key{mlsys}{chapter}{\renewcommand{\mlsyschapter}{#1}}
\define@key{mlsys}{chaptertitle}{\renewcommand{\mlsyschaptertitle}{#1}}
\define@key{mlsys}{logo}{\renewcommand{\mlsyslogopath}{#1}}
\define@key{mlsys}{instlogo}{\renewcommand{\mlsysinstlogo}{#1}}

\setbeamertemplate{headline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.6ex, dp=0.8ex]{section in head/foot}%
    \hspace{0.3em}{\fontsize{4.5}{5.5}\selectfont\insertsectionnavigationhorizontal{0.97\paperwidth}{}{}}\hspace{0.3em}%
  \end{beamercolorbox}}

\setbeamersize{mini frame size=0.08cm, mini frame offset=0.04cm}
\setbeamertemplate{mini frame}[circle]
\setbeamercolor{mini frame}{fg=white!70, bg=white!30}

\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.3pt]{palette primary}\end{beamercolorbox}%
  \begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, leftskip=0.7em, rightskip=0.7em]{normal text}%
    \raisebox{-0.2ex}{\includegraphics[height=2ex]{\mlsyslogopath}}\hspace{0.3em}%
    {\fontsize{6}{7}\selectfont\textcolor{lightgray}{Machine Learning Systems — \mlsysvolume{} — \mlsyschapter: \mlsyschaptertitle}}\hfill%
    {\fontsize{7}{8}\selectfont\textcolor{midgray}{\insertframenumber\,/\,\inserttotalframenumber}}\hspace{0.3em}%
    \raisebox{-0.3ex}{\includegraphics[height=2.2ex]{\mlsysinstlogo}}%
  \end{beamercolorbox}}

\setbeamertemplate{navigation symbols}{}

\newcounter{mlsystotalsections}
\setcounter{mlsystotalsections}{6}

\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, xshift=-0.3cm, yshift=0.3cm, opacity=0.04] at (current page.south east) {\fontsize{140}{140}\selectfont\bfseries\textcolor{forest}{\thesection}};
    \node[anchor=center] at (current page.center) {\begin{minipage}{0.8\paperwidth}\centering
      {\small\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \textbar{} \mlsyschapter}}}\\[0.4cm]
      {\fontsize{30}{36}\selectfont\bfseries\textcolor{forest}{\insertsectionhead}}\\[0.5cm]
      {\color{forest}\rule{3cm}{1.2pt}}\end{minipage}};
  \end{tikzpicture}}

\setstretch{1.1}
\setbeamertemplate{frametitle}{\vspace{0.3cm}\insertframetitle\par\vspace{-0.15cm}{\color{forest!20}\rule{\textwidth}{0.5pt}}}
\setbeamertemplate{itemize item}{\raisebox{0.15ex}{\color{forest}\scriptsize$\blacksquare$}}
\setbeamertemplate{itemize subitem}{\raisebox{0.2ex}{\color{forest!60}\tiny$\blacktriangleright$}}
\setbeamertemplate{enumerate item}{\small\bfseries\color{forest}\insertenumlabel.}

\newtcolorbox{mlsyscard}[2][]{enhanced, sharp corners, boxrule=0pt, frame hidden, borderline west={2.5pt}{0pt}{#2}, colback=#2!5, left=0.8em, right=0.8em, top=0.4em, bottom=0.4em, fontupper=\small, #1}

\newcommand{\mlsysfocus}[2]{{%
  \setbeamercolor{background canvas}{bg=darkforest}\setbeamercolor{normal text}{fg=white}%
  \setbeamercolor{section in head/foot}{fg=white!50, bg=darkforest}%
  \setbeamertemplate{footline}{\begin{beamercolorbox}[wd=\paperwidth, ht=2.8ex, dp=1.2ex, rightskip=0.7em]{normal text}\hfill{\fontsize{7}{8}\selectfont\textcolor{white!50}{\insertframenumber\,/\,\inserttotalframenumber}}\hspace{0.3em}\end{beamercolorbox}}%
  \begin{frame}[c]\centering\begin{minipage}{0.8\paperwidth}\centering{\color{white!50}\rule{2cm}{0.8pt}}\\[0.5cm]{\huge\bfseries\color{white} #1}\\[0.5cm]{\large\color{white!85} #2}\\[0.5cm]{\color{white!50}\rule{2cm}{0.8pt}}\end{minipage}\end{frame}}}

\newcommand{\Dvol}{D_{\text{vol}}}
\newcommand{\Rpeak}{R_{\text{peak}}}
\newcommand{\Llat}{L_{\text{lat}}}
\newcommand{\Ttotal}{T_{\text{total}}}

\newcommand{\mlsystitle}[3]{{%
  \setbeamertemplate{headline}{}\setbeamertemplate{footline}{\begin{beamercolorbox}[wd=\paperwidth, ht=0.6pt]{palette primary}\end{beamercolorbox}}%
  \begin{frame}[c]\begin{columns}[T]
    \begin{column}{0.60\textwidth}\vspace{1.2cm}
      {\footnotesize\textcolor{lightgray}{\MakeUppercase{\mlsysvolume{} \; | \; \mlsyschapter}}}\\[0.3cm]
      {\Huge\bfseries\textcolor{forest}{#1}}\\[0.2cm]{\color{forest}\rule{5cm}{0.5pt}}\\[0.3cm]
      {\large #2}\\[1.0cm]{\normalsize\textbf{\insertauthor}}\\[0.1cm]
      {\small\textcolor{lightgray}{\insertinstitute}}\\[0.2cm]{\footnotesize\textcolor{vlightgray}{\insertdate}}
    \end{column}
    \begin{column}{0.37\textwidth}\vspace{0.3cm}\IfFileExists{#3}{\includegraphics[width=\textwidth]{#3}}{}\end{column}
  \end{columns}\vfill
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south west, xshift=0.7cm, yshift=0.5cm] at (current page.south west) {\includegraphics[height=1.0cm]{\mlsyslogopath}};
    \node[anchor=south east, xshift=-0.7cm, yshift=0.5cm] at (current page.south east) {\includegraphics[height=1.0cm]{\mlsysinstlogo}};
  \end{tikzpicture}\end{frame}}}

\newcommand{\mlsysconcept}[2]{{\textcolor{forest}{\textbf{#1}} \; #2}}
\newcommand{\mlsysalert}[2]{{\textcolor{errorstroke}{\textbf{#1}} \; #2}}
\newcommand{\mlsysinsight}[2]{{\textcolor{datastroke}{\textbf{#1}} \; #2}}
\newcommand{\mlsyscite}[1]{\begin{tikzpicture}[remember picture, overlay]\node[anchor=south east, xshift=-3.5cm, yshift=0.45cm, font=\fontsize{5}{6}\selectfont\color{vlightgray}] at (current page.south east) {#1};\end{tikzpicture}}
\newtcolorbox{mlsyscode}{enhanced, sharp corners, boxrule=0pt, frame hidden, borderline west={2pt}{0pt}{midgray}, colback=vlightgray!30, left=0.6em, right=0.6em, top=0.3em, bottom=0.3em, fontupper=\small\ttfamily}
\newcommand{\mlsysref}[2]{{\small\textcolor{forest}{\textbf{[#1]}} #2}\\[0.2cm]}

\endinput
