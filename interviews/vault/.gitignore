# Top-level build artifact — release_hash is committed via
# corpus-equivalence-hash.txt (ARCHITECTURE.md §19.3 / M-4: commit manifest,
# not the transient build DB). Per-release vault.db under releases/<v>/ IS
# committed — it's the citable artifact (§13 Academic integrity).
/vault.db
/vault.db-journal
/vault.db-wal
/vault.db-shm

# Release artifacts staged during vault publish
releases/.pending-*/

# Runtime state
.publish.lock
.ship-journal.json
.llm-spend/

# Transient audit/probe outputs (underscore-prefixed JSON reports)
scripts/_*.json
# Local embedding cache (~15 MB) — regenerable from corpus, never commit
/embeddings.npz

# Regeneratable diagnostic — produced by diagnose_chain_coverage.py.
# Always derivable from chains.json + the YAML corpus; commit would just churn.
/chain-coverage.json

# AI pipeline scratch space. ALL intermediate outputs of LLM-driven
# tooling (chain proposals, gap detection, draft scorecards, audit
# runs) live here. Convention is documented in interviews/CLAUDE.md;
# scripts write to interviews/vault/_pipeline/ via the PIPELINE_DIR
# constant. Never commit anything under here — only durable corpus
# artifacts (chains.json, id-registry.yaml, questions/) belong in git.
/_pipeline/
