# Top-level build artifact — release_hash is committed via
# corpus-equivalence-hash.txt (ARCHITECTURE.md §19.3 / M-4: commit manifest,
# not the transient build DB). Per-release vault.db under releases/<v>/ IS
# committed — it's the citable artifact (§13 Academic integrity).
/vault.db
/vault.db-journal
/vault.db-wal
/vault.db-shm

# Release artifacts staged during vault publish
releases/.pending-*/

# Runtime state
.publish.lock
.ship-journal.json
.llm-spend/
