digraph G {
  rankdir=TB;
  node [shape=box, style=filled, fontname="Helvetica"];
  
  subgraph cluster_spine {
    label = "Spine Tier";
    style = dashed;
    color = gray;
    S1 [label="Spine 1\n(8 downlinks)", fillcolor="#cfe2f3", color="#4a90c4"];
    S2 [label="Spine 2\n(8 downlinks)", fillcolor="#cfe2f3", color="#4a90c4"];
  }

  subgraph cluster_leaf {
    label = "Leaf Tier (2:1 Oversubscribed)";
    style = dashed;
    color = gray;
    L1 [label="Leaf 1\n(8 up, 16 down)", fillcolor="#cfe2f3", color="#4a90c4"];
    L2 [label="Leaf 2\n(8 up, 16 down)", fillcolor="#cfe2f3", color="#4a90c4"];
    L3 [label="Leaf 3\n(8 up, 16 down)", fillcolor="#cfe2f3", color="#4a90c4"];
    L4 [label="Leaf 4\n(8 up, 16 down)", fillcolor="#cfe2f3", color="#4a90c4"];
  }

  subgraph cluster_compute {
    label = "Compute Nodes (8x H100 each)";
    style = dashed;
    color = gray;
    N1 [label="N1", fillcolor="#d4edda", color="#3d9e5a"];
    N2 [label="N2", fillcolor="#d4edda", color="#3d9e5a"];
    N3 [label="N3", fillcolor="#d4edda", color="#3d9e5a"];
    N4 [label="N4", fillcolor="#d4edda", color="#3d9e5a"];
    N5 [label="N5", fillcolor="#d4edda", color="#3d9e5a"];
    N6 [label="N6", fillcolor="#d4edda", color="#3d9e5a"];
    N7 [label="N7", fillcolor="#d4edda", color="#3d9e5a"];
    N8 [label="N8", fillcolor="#d4edda", color="#3d9e5a"];
  }

  S1 -> {L1 L2 L3 L4} [dir=both, color="#c87b2a", penwidth=1.5];
  S2 -> {L1 L2 L3 L4} [dir=both, color="#c87b2a", penwidth=1.5];

  L1 -> {N1 N2} [dir=both, color="#3d9e5a"];
  L2 -> {N3 N4} [dir=both, color="#3d9e5a"];
  L3 -> {N5 N6} [dir=both, color="#3d9e5a"];
  L4 -> {N7 N8} [dir=both, color="#3d9e5a"];
}