digraph G {
  rankdir=LR;
  node [style=filled, fontname="Helvetica", shape=box];
  Cams [label="8x 1080p30\n(~12 Gbps)", fillcolor="#fdebd0"];
  Switch [label="Gigabit Switch\n(1 Gbps)", fillcolor="#cfe2f3", color="#4a90c4"];
  Orin [label="Jetson Orin", fillcolor="#d4edda", color="#3d9e5a"];
  Cams -> Switch [label="Overflow", color="#c87b2a", penwidth=3];
  Switch -> Orin;
}