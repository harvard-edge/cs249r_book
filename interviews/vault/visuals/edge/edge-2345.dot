digraph G {
  node [style=filled, fontname="Helvetica", shape=box];
  edge [penwidth=2, color="#666666"];
  Cameras [label="8x 4K Cameras\n(~6 GB/s)", fillcolor="#fdebd0", color="#c87b2a"];
  Switch [label="PCIe Gen3 x8 Switch", fillcolor="#cfe2f3", color="#4a90c4"];
  H1 [label="Hailo-8 (1)", fillcolor="#d4edda", color="#3d9e5a"];
  H2 [label="Hailo-8 (2)", fillcolor="#d4edda", color="#3d9e5a"];
  Cameras -> Switch;
  Switch -> H1;
  Switch -> H2;
}