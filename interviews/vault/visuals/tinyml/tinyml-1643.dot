digraph G {
  rankdir=LR;
  node [style=filled, fontname="Helvetica", shape=box];
  BLE [label="10x BLE\n(100 KB/s)", fillcolor="#fdebd0"];
  MCU [label="Cortex-M4\nInference", fillcolor="#cfe2f3", color="#4a90c4"];
  WiFi [label="WiFi Module\n(11.5 KB/s)", fillcolor="#d4edda", color="#3d9e5a"];
  BLE -> MCU;
  MCU -> WiFi [label="UART", color="#c87b2a", penwidth=3];
}