digraph G {
  rankdir=BT;
  node [style=filled, fontname="Helvetica", shape=ellipse, fillcolor="#fdebd0"];
  S1 [label="Sensor"];
  S2 [label="Sensor"];
  S3 [label="Sensor"];
  Bus [shape=box, label="I2C Bus (400 kbps)", fillcolor="#cfe2f3", color="#4a90c4"];
  MCU [shape=box, label="Cortex-M4", fillcolor="#d4edda", color="#3d9e5a"];
  S1 -> Bus;
  S2 -> Bus;
  S3 -> Bus;
  Bus -> MCU;
}