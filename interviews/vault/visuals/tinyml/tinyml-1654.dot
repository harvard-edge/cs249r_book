digraph G {
  rankdir=LR;
  node [style=filled, fontname="Helvetica", shape=box, fillcolor="#cfe2f3", color="#4a90c4"];
  edge [color="#c87b2a", penwidth=2];
  App [label="App Payload\n(< 100 kbps)"];
  Stack [label="L2CAP/GATT\nOverhead", fillcolor="#fdebd0"];
  PHY [label="BLE PHY\n(1 Mbps)", fillcolor="#d4edda"];
  App -> Stack -> PHY;
}