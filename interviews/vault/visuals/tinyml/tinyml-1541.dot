digraph G {
    rankdir=LR;
    node [style=filled, fillcolor="#cfe2f3", color="#4a90c4", shape=box, fontname="Helvetica"];
    Sensor_1 -> BLE_Link;
    Sensor_2 -> BLE_Link;
    Sensor_N -> BLE_Link;
    BLE_Link [shape=oval, fillcolor="#fdebd0", color="#c87b2a", label="250 kbps BLE"];
    Central_Hub [fillcolor="#d4edda", color="#3d9e5a", label="Central Hub"];
    BLE_Link -> Central_Hub;
}