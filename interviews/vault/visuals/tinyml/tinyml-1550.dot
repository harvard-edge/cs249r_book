digraph G {
    node [style=filled, fontname="Helvetica", shape=circle];
    Master [fillcolor="#cfe2f3", color="#4a90c4", label="M4"];
    S1 [fillcolor="#d4edda", color="#3d9e5a", label="S1"];
    S2 [fillcolor="#d4edda", color="#3d9e5a", label="S2"];
    S3 [fillcolor="#d4edda", color="#3d9e5a", label="S3"];
    Master -> S1 [label="I2C", dir=both];
    Master -> S2 [label="I2C", dir=both];
    Master -> S3 [label="I2C", dir=both];
}