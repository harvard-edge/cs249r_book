digraph G {
  rankdir=LR;
  node [style=filled, fontname="Helvetica"];
  n1 [label="M4 1", fillcolor="#cfe2f3", color="#4a90c4"];
  n2 [label="M4 2", fillcolor="#cfe2f3", color="#4a90c4"];
  n3 [label="M4 3", fillcolor="#cfe2f3", color="#4a90c4"];
  n4 [label="M4 4", fillcolor="#d4edda", color="#3d9e5a"];
  zigbee [label="Zigbee\n250 kbps", fillcolor="#fdebd0", color="#c87b2a"];
  n1 -> zigbee;
  n2 -> zigbee;
  n3 -> zigbee;
  n4 -> zigbee [style=dashed];
}