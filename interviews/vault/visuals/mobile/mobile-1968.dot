digraph G {
  rankdir=LR;
  node [style=filled, fontname="Helvetica", shape=box];
  Encoder [label="Video Encoder\n(4K -> 1080p)", fillcolor="#cfe2f3"];
  Network [label="5G Network\n(Variable BW)", fillcolor="#fdebd0"];
  Receiver [label="Client", fillcolor="#d4edda"];
  Encoder -> Network [label="Bitrate"];
  Network -> Receiver;
  Receiver -> Encoder [label="BW Feedback", style="dashed"];
}