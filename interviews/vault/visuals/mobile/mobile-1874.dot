digraph G {
    rankdir=LR;
    node [style=filled, fontname="Helvetica", shape=box];
    Watch [fillcolor="#cfe2f3", color="#4a90c4", label="Apple Watch\n(Early Layers)"];
    Phone [fillcolor="#d4edda", color="#3d9e5a", label="A17 Pro\n(Late Layers)"];
    Watch -> Phone [label="BLE < 25 KB\n(100ms max)", color="#c87b2a", penwidth=2];
}