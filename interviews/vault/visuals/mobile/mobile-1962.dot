digraph G {
  rankdir=BT;
  node [style=filled, fontname="Helvetica", shape=ellipse];
  D1 [label="Device 1", fillcolor="#fdebd0"];
  D2 [label="Device 2", fillcolor="#fdebd0"];
  RegEdge [label="Regional RegEdge", fillcolor="#cfe2f3", color="#4a90c4"];
  Cloud [label="Central Cloud", fillcolor="#d4edda", color="#3d9e5a", shape=box];
  D1 -> RegEdge;
  D2 -> RegEdge;
  RegEdge -> Cloud;
}