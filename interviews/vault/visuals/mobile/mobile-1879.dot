digraph G {
    rankdir=LR;
    node [style=filled, fontname="Helvetica", shape=box];
    Cloud [fillcolor="#cfe2f3", color="#4a90c4", label="20MB Model"];
    Chunker [fillcolor="#fdebd0", color="#c87b2a", label="Slice: 50 KB"];
    WASM [fillcolor="#d4edda", color="#3d9e5a", label="Browser UI\n(10Hz updates)"];
    Cloud -> Chunker;
    Chunker -> WASM [label="4 Mbps", penwidth=2, color="#c87b2a"];
}