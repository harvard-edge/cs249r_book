digraph G {
    rankdir=LR;
    node [style=filled, fontname="Helvetica", shape=box];
    Seg_Model [fillcolor="#cfe2f3", color="#4a90c4", label="Segmentation\n(62 Mbps raw)"];
    RLE [fillcolor="#fdebd0", color="#c87b2a", label="Run-Length\nEncoding"];
    Cloud [fillcolor="#d4edda", color="#3d9e5a", label="Cloud Server"];
    Seg_Model -> RLE;
    RLE -> Cloud [label="5 Mbps 4G", color="#c87b2a", penwidth=2];
}