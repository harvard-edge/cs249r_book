# Build output (generated by `npm run build` with static export)
out/
.next/

# Auto-generated by Next.js. The committed copy churned constantly under
# Next 16 + Turbopack: `next dev` writes `import "./.next/dev/types/..."`
# while `next build` writes `import "./.next/types/..."`, so every commit
# from a different mode flipped the line. Next.js docs say to commit it,
# but that guidance predates the dev/prod path split. Regenerated locally
# on first `next dev` / `next build`.
next-env.d.ts

# Dependencies
node_modules/

# Cloudflare Wrangler cache (worker dev/deploy)
worker/.wrangler/
worker/wrangler.toml.bak
tsconfig.tsbuildinfo

# Build output — `vault build --local-json` mirrors SVG assets from
# interviews/vault/visuals/ into public/question-visuals/. The vault
# is the source of truth; don't commit the copy.
public/question-visuals/

# Build output — `vault build --local` materializes the full corpus from
# vault/questions/*.yaml. Both copies are regenerated on every `npm run dev`
# by the predev hook, so they're build artifacts, not source. The vault
# YAMLs are the source of truth.
src/data/corpus.json
public/data/corpus.json

# Playwright test artifacts (screenshots, videos, traces on failure).
# The `tests/` directory itself IS committed.
test-results/
playwright-report/

# Output from tests/responsive-audit.mjs and tests/navbar-containment-diff.mjs
# (per-viewport screenshots + report.json). The scripts ARE committed; their
# output is a build artifact (~100MB per run) and should be regenerated
# locally when needed.
tests/responsive-output/
