\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The \textsc  {StaffML}{} ikigai competency model.} Four fundamental skills (Recall, Analyze, Design, Quantify) overlap to produce six compound zones and one central mastery zone. Each question targets exactly one zone, which determines \emph  {how} a topic is assessed. The compound zones capture the cognitive acts that distinguish Staff-level engineers: diagnosing failures (Recall $\cap $ Analyze), translating specifications into architectures (Recall $\cap $ Design), performing napkin math from memory (Recall $\cap $ Quantify), evaluating architectural alternatives (Analyze $\cap $ Design), sizing concrete systems (Design $\cap $ Quantify), and optimizing bottlenecks (Analyze $\cap $ Quantify).}}{5}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:competency-model}{{1}{5}{\textbf {The \staffml {} ikigai competency model.} Four fundamental skills (Recall, Analyze, Design, Quantify) overlap to produce six compound zones and one central mastery zone. Each question targets exactly one zone, which determines \emph {how} a topic is assessed. The compound zones capture the cognitive acts that distinguish Staff-level engineers: diagnosing failures (Recall $\cap $ Analyze), translating specifications into architectures (Recall $\cap $ Design), performing napkin math from memory (Recall $\cap $ Quantify), evaluating architectural alternatives (Analyze $\cap $ Design), sizing concrete systems (Design $\cap $ Quantify), and optimizing bottlenecks (Analyze $\cap $ Quantify)}{figure.caption.1}{}}
\newlabel{fig:competency-model@cref}{{[figure][1][]1}{[1][4][]5}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Four-axis classification.} Every question is independently classified by \emph  {topic} (what concept is tested), \emph  {zone} (how the concept is tested), \emph  {track} (which physics regime applies), and \emph  {level} (what cognitive depth is required). The axes are orthogonal: any valid combination defines a unique assessment cell.}}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:four-axes}{{2}{5}{\textbf {Four-axis classification.} Every question is independently classified by \emph {topic} (what concept is tested), \emph {zone} (how the concept is tested), \emph {track} (which physics regime applies), and \emph {level} (what cognitive depth is required). The axes are orthogonal: any valid combination defines a unique assessment cell}{figure.caption.3}{}}
\newlabel{fig:four-axes@cref}{{[figure][2][]2}{[1][4][]5}{}{}{}}
