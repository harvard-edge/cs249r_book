{
  "MLSys Scenario (Basic)": {
    "scope": "yaml",
    "prefix": "mlsys-scenario",
    "description": "Basic mlsysim scenario: workload + hardware",
    "body": [
      "version: \"1.0\"",
      "name: \"${1:Scenario Name}\"",
      "",
      "workload:",
      "  name: \"${2|Llama3_8B,Llama3_70B,GPT3,GPT4,ResNet50,BERT_Base,DLRM|}\"",
      "  batch_size: ${3:1}",
      "  seq_len: ${4:2048}",
      "",
      "hardware:",
      "  name: \"${5|H100,H200,B200,A100,V100,T4,MI300X,TPUv5p|}\"",
      "  nodes: ${6:1}",
      "  precision: \"${7|fp16,bf16,fp32,fp8,int8,int4|}\"",
      "  efficiency: ${8:0.5}"
    ]
  },
  "MLSys Scenario (Fleet)": {
    "scope": "yaml",
    "prefix": "mlsys-fleet",
    "description": "Fleet scenario with ops and constraints",
    "body": [
      "version: \"1.0\"",
      "name: \"${1:Fleet Scenario}\"",
      "",
      "workload:",
      "  name: \"${2:Llama3_70B}\"",
      "  batch_size: ${3:32}",
      "  seq_len: ${4:2048}",
      "",
      "hardware:",
      "  name: \"${5:H100}\"",
      "  nodes: ${6:64}",
      "  precision: \"${7:fp16}\"",
      "  efficiency: ${8:0.5}",
      "",
      "ops:",
      "  region: \"${9|US_Avg,Quebec,Poland|}\"",
      "  duration_days: ${10:30}",
      "",
      "constraints:",
      "  assert:",
      "    - metric: \"${11|feasibility.fits_in_memory,performance.latency_ms,economics.tco_usd|}\"",
      "      ${12|min,max|}: ${13:1}"
    ]
  },
  "MLSys Scenario (Serving)": {
    "scope": "yaml",
    "prefix": "mlsys-serving",
    "description": "LLM serving scenario with latency constraints",
    "body": [
      "version: \"1.0\"",
      "name: \"${1:Serving Scenario}\"",
      "",
      "workload:",
      "  name: \"${2:Llama3_8B}\"",
      "  batch_size: ${3:1}",
      "  seq_len: ${4:4096}",
      "",
      "hardware:",
      "  name: \"${5:H100}\"",
      "  nodes: ${6:1}",
      "  precision: \"${7:fp16}\"",
      "  efficiency: ${8:0.5}",
      "",
      "constraints:",
      "  assert:",
      "    - metric: \"performance.latency_ms\"",
      "      max: ${9:50}"
    ]
  }
}
