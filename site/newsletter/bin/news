#!/usr/bin/env python3
"""news CLI wrapper — runs without pip install.

Usage:
    site/newsletter/bin/news <command> [options]

Add to your PATH or alias for convenience:
    alias news='/Users/VJ/GitHub/MLSysBook-newsletter/site/newsletter/bin/news'
"""
import os
import sys
from pathlib import Path

# Resolve the newsletter directory from this file's location.
newsletter_root = Path(__file__).resolve().parent.parent

# Put `site/newsletter/` on the path so `from cli.main import main` works.
sys.path.insert(0, str(newsletter_root))

from cli.main import main

sys.exit(main())
